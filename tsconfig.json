{
  "compilerOptions": {
    "target": "es2017",
    "lib": ["es2017", "dom", "esnext"],
    "module": "commonjs",
    "rootDir": "./src/",
    "types": ["node", "jest"],
    "outDir": "./dist/",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true
  },
  "exclude": ["node_modules", "dist"]
}
